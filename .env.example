# ── Core security ─────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-this-with-a-random-long-string

# Separate key for encrypting stored integration credentials (Shopify token, SMTP password).
# Must stay stable — changing it invalidates all saved credentials.
CREDENTIAL_ENCRYPTION_KEY=replace-this-with-another-random-long-string

# ── Admin account ─────────────────────────────────────────────────────────────
DEMO_USERNAME=admin
DEMO_PASSWORD=ChangeMe123!

# ── Database ──────────────────────────────────────────────────────────────────
# Default: SQLite at instance/opsdemo.db
# For PostgreSQL: postgresql://user:pass@host:5432/dbname
# DATABASE_URL=sqlite:///instance/opsdemo.db

# ── Session / app ─────────────────────────────────────────────────────────────
ALERT_LOOKAHEAD_DAYS=30
PERMANENT_SESSION_LIFETIME_SECONDS=28800
# Set to true only when serving over HTTPS
SESSION_COOKIE_SECURE=false

# ── Shopify integration ────────────────────────────────────────────────────────
# Direct access-token (Custom App) flow — works locally without a public URL.
# Create a Custom App in Shopify admin → Apps → Develop apps,
# grant read_customers and read_orders scopes, copy the Admin API access token,
# then paste it into Settings → Integrations → Shopify inside the app.
SHOPIFY_API_VERSION=2026-04

# OAuth flow — requires a publicly reachable URL. Not needed for the Custom App flow.
# For local testing expose this app with ngrok or Cloudflare Tunnel, then fill these in:
# SHOPIFY_API_KEY=
# SHOPIFY_API_SECRET=
# SHOPIFY_REDIRECT_URI=https://yourdomain.com/shopify/callback
# PUBLIC_BASE_URL=https://yourdomain.com
